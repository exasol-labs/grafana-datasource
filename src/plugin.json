{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Exasol",
  "id": "exasol-exasol-datasource",
  "metrics": true,
  "annotations": true,
  "alerting": true,
  "backend": true,
  "executable": "gpx_exasol",
  "info": {
    "description": "Exasol datasource plugin for Grafana. Execute SQL queries directly against Exasol databases.",
    "author": {
      "name": "Dren Daka",
      "url": "https://github.com/ddaka"
    },
    "keywords": ["datasource", "exasol", "sql", "database"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "Repository",
        "url": "https://github.com/exasol-labs/grafana-datasource"
      },
      {
        "name": "Documentation",
        "url": "https://github.com/exasol-labs/grafana-datasource#readme"
      },
      {
        "name": "License",
        "url": "https://github.com/exasol-labs/grafana-datasource/blob/main/LICENSE"
      },
      {
        "name": "Sponsorship",
        "url": "https://github.com/sponsors/exasol"
      }
    ],
    "screenshots": [
      {
        "name": "Datasource configuration",
        "path": "img/config-editor.png"
      },
      {
        "name": "Query editor with results",
        "path": "img/query-editor.png"
      },
      {
        "name": "Time-series query with $__timeGroupAlias",
        "path": "img/time-series.png"
      }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "plugins": []
  }
}
