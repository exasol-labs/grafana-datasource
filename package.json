{
  "name": "exasol-exasol-datasource",
  "version": "1.0.2",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "build:backend": "go run github.com/magefile/mage -v buildAll",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "package": "npm run build && npm run build:backend && ./scripts/package-plugin.sh",
    "package:archive": "./scripts/package-plugin.sh",
    "validate:plugin": "ARCHIVE=$(npm run --silent package) && ./scripts/validate-plugin.sh \"$ARCHIVE\"",
    "validate:plugin:local": "./scripts/validate-plugin.sh exasol-exasol-datasource.zip",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": "Exasol",
  "license": "MIT",
  "devDependencies": {
    "@grafana/eslint-config": "^10.0.0",
    "@grafana/plugin-e2e": "^3.9.1",
    "@grafana/tsconfig": "^2.2.0",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.9.1",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.101.0",
    "sass-loader": "^16.0.0",
    "semver": "^7.8.5",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-node": "^10.9.0",
    "typescript": "7.0.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^7.2.1",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "^13.1.0",
    "@grafana/i18n": "^13.1.0",
    "@grafana/runtime": "^13.1.0",
    "@grafana/schema": "^13.1.0",
    "@grafana/ui": "^13.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "packageManager": "npm@11.8.0"
}
